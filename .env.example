# ========================================
# йҗңоҲҡо•ЁйҚҷж©Җеҷәй–°е¶Үз–Ҷз»ҖиҪ°з·Ҙ
# жҫ¶е¶…еҹ—е§қгӮҶжһғжө жңөиҙҹ .env йӘһи·әпҪһйҚҸгғҘз–„й—„е‘ӯвӮ¬?
# ========================================

# ========================================
# йҸҒзүҲеөҒжҗҙж’»еҺӨзјғ?
# ========================================
DB_URL=jdbc:mysql://localhost:3306/aiwechat?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ========================================
# еҜ°оҶ»дҝҠзҒҸеҝ•в–јжҗҙеҝӣеҺӨзјғ?
# ========================================
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# ========================================
# ModelScope AI й–°е¶Үз–Ҷ
# ========================================
MODELSCOPE_API_KEY=your_modelscope_api_key_here

# RAG Embedding еҰҜвҖізҖ·й–°е¶Үз–Ҷй”ӣе ҹж«Өз’Ӣзӣ§penAI йҚҸз…ҺоҶҗйҺәгғҘеҪӣй”ӣ?
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3

# ========================================
# жҘӮжЁәз—үйҚҰжқҝжөҳй–°е¶Үз–Ҷ
# ========================================
AMAP_API_KEY=your_amap_api_key_here

# ========================================
# Redis й–°е¶Үз–Ҷй”ӣе қеҪІй–«еӨӣзҙҡ
# ========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ========================================
# йҚҡжҲҰеҷәзҖӣжЁәеҒҚй–°е¶Үз–Ҷй”ӣең§AGй”ӣ?
# ========================================
VECTORSTORE_PATH=./uploaded/vectorstore.json

# ========================================
# Nacos Config Center
# ========================================
# Use namespace ID (UUID), not namespace display name. Leave empty to use public namespace.
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
# Must match publish-config.ps1 -Group and service startup environment.
NACOS_GROUP=AIWECHAT_GROUP
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security
NACOS_AUTH_TOKEN=change_me_nacos_token

# ========================================
# Service Routing / Admin
# ========================================
AUTH_SERVICE_URI=http://localhost:9091
AUTH_SERVICE_URL=http://localhost:9091
BUSINESS_SERVICE_URI=http://localhost:9092
ADMIN_AUTH_SECRET=please_change_admin_secret
ADMIN_AUTH_USERNAME=admin
ADMIN_AUTH_PASSWORD=admin123

# ========================================
# App Runtime
# ========================================
TOKEN_EXPIRE_HOURS=72
AI_BASE_URL=https://api-inference.modelscope.cn/v1
AI_MODEL=qwen/Qwen3-1.7B
AI_TEMPERATURE=0.7
AI_MODEL_INDEX=0
CHAT_HISTORY_LIMIT=10
KNOWLEDGE_SYNC_ENABLED=true
KNOWLEDGE_SYNC_CRON=0 0 3 * * ?
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60
