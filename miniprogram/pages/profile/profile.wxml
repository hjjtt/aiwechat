<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="header-bg">
      <view class="header-pattern"></view>
    </view>
    <view class="user-card" bindtap="goToLogin">
      <view class="avatar-wrap">
        <image class="avatar-img" wx:if="{{avatarUrl && avatarUrl != '/images/default-avatar.png'}}" src="{{avatarUrl}}" mode="aspectFill"></image>
        <view class="avatar-placeholder" wx:else>
          <text class="avatar-icon">👤</text>
        </view>
        <view class="avatar-badge" wx:if="{{!isLoggedIn}}">点击登录</view>
      </view>
      <view class="user-info">
        <view class="nickname">{{nickname || '游客用户'}}</view>
        <view class="user-id-wrap" wx:if="{{userId}}">
          <text class="user-id-icon">🏷️</text>
          <text class="user-id">{{userId}}</text>
        </view>
        <view class="user-tags" wx:if="{{isLoggedIn}}">
          <view class="tag vip">
            <text class="tag-icon">👑</text>
            <text>VIP会员</text>
          </view>
        </view>
      </view>
      <view class="arrow-right" wx:if="{{!isLoggedIn}}">></view>
    </view>
  </view>

  <!-- 订单统计 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-item">
        <view class="stats-num">{{orderStats.pending}}</view>
        <view class="stats-label">待付款</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{orderStats.paid}}</view>
        <view class="stats-label">待发货</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{orderStats.delivering}}</view>
        <view class="stats-label">待收货</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{orderStats.completed}}</view>
        <view class="stats-label">已完成</view>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="section-title">常用功能</view>
    <view class="menu-grid">
      <view class="menu-item" bindtap="navigateToChat">
        <view class="item-icon-wrap chat">
          <text class="item-icon">💬</text>
        </view>
        <view class="item-text">AI客服对话</view>
      </view>
      <view class="menu-item" bindtap="navigateToOrders">
        <view class="item-icon-wrap order">
          <text class="item-icon">📋</text>
        </view>
        <view class="item-text">我的订单</view>
      </view>
      <view class="menu-item" bindtap="showAddress">
        <view class="item-icon-wrap address">
          <text class="item-icon">📍</text>
        </view>
        <view class="item-text">收货地址</view>
      </view>
      <view class="menu-item" bindtap="showFavorites">
        <view class="item-icon-wrap favorite">
          <text class="item-icon">❤️</text>
        </view>
        <view class="item-text">我的收藏</view>
      </view>
    </view>
  </view>

  <!-- 服务列表 -->
  <view class="menu-section">
    <view class="section-title">更多服务</view>
    <view class="menu-list-card">
      <view class="menu-row" bindtap="showHelp">
        <view class="row-left">
          <text class="row-icon">❓</text>
          <text class="row-text">帮助中心</text>
        </view>
        <text class="row-arrow">></text>
      </view>
      <view class="menu-row" bindtap="contactService">
        <view class="row-left">
          <text class="row-icon">📞</text>
          <text class="row-text">联系客服</text>
        </view>
        <text class="row-arrow">></text>
      </view>
      <view class="menu-row" bindtap="showAbout">
        <view class="row-left">
          <text class="row-icon">ℹ️</text>
          <text class="row-text">关于我们</text>
        </view>
        <text class="row-arrow">></text>
      </view>
      <view class="menu-row" bindtap="showFeedback">
        <view class="row-left">
          <text class="row-icon">💭</text>
          <text class="row-text">意见反馈</text>
        </view>
        <text class="row-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="logout">
      <text class="logout-icon">🚪</text>
      <text>退出登录</text>
    </view>
  </view>

  <!-- 底部版权 -->
  <view class="footer-copyright">
    <text>任氏外卖 · 智能点餐系统</text>
  </view>
</view>
