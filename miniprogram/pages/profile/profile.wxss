/* 个人中心页 - 日系治愈原木风 */
page {
  background: #f9f5f0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>'),
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" opacity="0.03"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="200" height="200" filter="url(%23noise)"/></svg>');
  background-size: 100rpx 100rpx, 200rpx 200rpx;
}

.container {
  min-height: 100vh;
  padding-bottom: 80rpx;
}

/* ==================== 个人信息头部 ==================== */
.profile-header {
  position: relative;
  padding-top: 60rpx;
  margin-bottom: 32rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 50%, #b8d8be 100%);
  overflow: hidden;
}

.header-bg::before,
.header-bg::after {
  content: '';
  position: absolute;
  opacity: 0.6;
}

.header-bg::before {
  content: '👤';
  top: 80rpx;
  left: 60rpx;
  font-size: 32rpx;
  animation: floatSoft 5s ease-in-out infinite;
}

.header-bg::after {
  content: '🌿';
  top: 120rpx;
  right: 80rpx;
  font-size: 28rpx;
  animation: floatSoft 6s ease-in-out infinite reverse;
}

.header-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text x="15" y="25" font-size="10" fill="rgba(255,255,255,0.2)">🌱</text><text x="65" y="50" font-size="8" fill="rgba(255,255,255,0.15)">🍃</text></svg>');
  background-size: 120rpx 120rpx;
}

.user-card {
  position: relative;
  z-index: 2;
  margin: 0 24rpx;
  background: #fffbf5;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 
    0 4rpx 0 #e8ded2,
    0 8rpx 20rpx rgba(139,115,85,0.1);
  border: 2rpx solid #e8ded2;
  transition: all 0.2s;
}

.user-card:active {
  transform: translateY(2rpx);
  box-shadow: 
    0 2rpx 0 #e8ded2,
    0 4rpx 12rpx rgba(139,115,85,0.08);
}

/* 和纸胶带装饰 */
.user-card::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  width: 100rpx;
  height: 20rpx;
  background: rgba(212,184,134,0.4);
  border-radius: 2rpx;
}

.avatar-wrap {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 3rpx 8rpx rgba(193,154,107,0.2);
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
  box-shadow: 0 3rpx 8rpx rgba(193,154,107,0.2);
}

.avatar-icon {
  font-size: 48rpx;
}

.avatar-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  border: 1rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.2);
}

.user-info {
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #5c4b37;
  margin-bottom: 8rpx;
}

.user-id-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-id-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
  opacity: 0.7;
}

.user-id {
  font-size: 20rpx;
  color: #998675;
  font-weight: 300;
}

.user-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  display: flex;
  align-items: center;
  padding: 4rpx 10rpx;
  background: rgba(240,184,109,0.1);
  border-radius: 8rpx;
}

.tag-icon {
  font-size: 16rpx;
  margin-right: 4rpx;
}

.tag text {
  font-size: 18rpx;
  color: #e8b86d;
  font-weight: 500;
}

.arrow-right {
  font-size: 28rpx;
  color: #998675;
  font-weight: 300;
  flex-shrink: 0;
}

/* ==================== 订单统计 ==================== */
.stats-section {
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.stats-card {
  background: #fffbf5;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  border: 2rpx solid #e8ded2;
  position: relative;
  transform: rotate(-0.3deg);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #c19a6b;
  margin-bottom: 6rpx;
}

.stats-label {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
}

/* ==================== 功能列表 ==================== */
.menu-section {
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5c4b37;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.menu-item {
  background: #fffbf5;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  border: 2rpx solid #e8ded2;
  transition: all 0.2s;
  position: relative;
  transform: rotate(var(--rotate, 0deg));
}

.menu-item:nth-child(1) { --rotate: -0.5deg; }
.menu-item:nth-child(2) { --rotate: 0.6deg; }
.menu-item:nth-child(3) { --rotate: 0.4deg; }
.menu-item:nth-child(4) { --rotate: -0.3deg; }

.menu-item:active {
  transform: scale(0.96) rotate(var(--rotate, 0deg));
}

.item-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(193,154,107,0.2);
}

.item-icon {
  font-size: 32rpx;
}

.item-icon-wrap.chat {
  background: linear-gradient(135deg, #b8d8e8 0%, #8ab6d6 100%);
}

.item-icon-wrap.order {
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
}

.item-icon-wrap.address {
  background: linear-gradient(135deg, #f5a9a9 0%, #f08080 100%);
}

.item-icon-wrap.favorite {
  background: linear-gradient(135deg, #f0d0e0 0%, #e8a8c8 100%);
}

.item-text {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 500;
}

/* ==================== 服务列表 ==================== */
.menu-list-card {
  background: #fffbf5;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  border: 2rpx solid #e8ded2;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(232,222,210,0.5);
  transition: all 0.2s;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-row:active {
  background: #f1ebe4;
}

.row-left {
  display: flex;
  align-items: center;
}

.row-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(212,184,134,0.1);
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.row-text {
  font-size: 26rpx;
  color: #5c4b37;
  font-weight: 400;
}

.row-arrow {
  font-size: 24rpx;
  color: #998675;
  font-weight: 300;
}

/* ==================== 退出登录 ==================== */
.logout-section {
  padding: 0 24rpx;
  margin-bottom: 40rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  background: rgba(240,128,128,0.1);
  border: 2rpx solid rgba(240,128,128,0.3);
  border-radius: 16rpx;
  color: #f08080;
  font-size: 26rpx;
  font-weight: 500;
}

.logout-btn:active {
  background: rgba(240,128,128,0.2);
  transform: scale(0.98);
}

.logout-icon {
  font-size: 22rpx;
}

/* ==================== 底部版权 ==================== */
.footer-copyright {
  text-align: center;
  padding: 24rpx 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.footer-copyright text {
  font-size: 20rpx;
  color: #998675;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* 公共动画 */
@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}