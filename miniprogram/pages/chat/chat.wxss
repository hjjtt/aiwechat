/* 客服页 - 日系治愈原木风 */
page {
  background: #f9f5f0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>'),
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" opacity="0.03"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="200" height="200" filter="url(%23noise)"/></svg>');
  background-size: 100rpx 100rpx, 200rpx 200rpx;
}

.chat-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 手绘背景装饰 */
.chat-container::before,
.chat-container::after {
  content: '';
  position: absolute;
  opacity: 0.4;
  z-index: 0;
  animation: floatSoft 8s ease-in-out infinite;
}

.chat-container::before {
  content: '☕';
  top: 120rpx;
  left: 20rpx;
  font-size: 28rpx;
  animation-delay: 0s;
}

.chat-container::after {
  content: '🍞';
  top: 280rpx;
  right: 20rpx;
  font-size: 24rpx;
  animation-delay: 3s;
}

/* ==================== 聊天消息区域 ==================== */
.chat-messages {
  flex: 1;
  padding: 20rpx 24rpx 20rpx;
  position: relative;
  z-index: 1;
}

.messages-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.message {
  display: flex;
  gap: 12rpx;
  transform: rotate(var(--rotate, 0deg));
}

.message:nth-child(odd) { --rotate: -0.3deg; }
.message:nth-child(even) { --rotate: 0.2deg; }

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(139,115,85,0.1);
  flex-shrink: 0;
}

.assistant-avatar {
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  color: #5c4b37;
}

.user-avatar {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
}

.avatar-icon {
  font-size: 28rpx;
}

.message-bubble {
  max-width: 70%;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e8ded2;
  box-shadow: 0 3rpx 8rpx rgba(139,115,85,0.08);
  position: relative;
}

.assistant-bubble {
  background: #fffbf5;
  border-top-left-radius: 4rpx;
  color: #5c4b37;
  margin-right: auto;
}

.user-bubble {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  border-top-right-radius: 4rpx;
  color: #fff;
  margin-left: auto;
}

.bubble-content {
  font-size: 26rpx;
  line-height: 1.6;
  font-weight: 400;
  white-space: pre-line;
}

.msg-image {
  max-width: 300rpx;
  max-height: 300rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  object-fit: cover;
}

/* 欢迎消息 */
.welcome-message {
  align-items: flex-start;
}

.welcome-content {
  max-width: 80%;
  background: #fffbf5;
  border-radius: 20rpx;
  border: 2rpx solid #e8ded2;
  padding: 24rpx;
  box-shadow: 0 3rpx 8rpx rgba(139,115,85,0.08);
}

.welcome-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #5c4b37;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 24rpx;
  color: #998675;
  margin-bottom: 12rpx;
  font-weight: 300;
}

.welcome-item {
  font-size: 24rpx;
  color: #5c4b37;
  margin-bottom: 6rpx;
  font-weight: 400;
}

/* 加载中状态 */
.loading {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.loading-content {
  background: #fffbf5;
  border-radius: 20rpx;
  border: 2rpx solid #e8ded2;
  padding: 16rpx 20rpx;
  border-top-left-radius: 4rpx;
  min-width: 120rpx;
}

.loading-dots {
  display: flex;
  gap: 4rpx;
  margin-bottom: 4rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #c19a6b;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.loading-text {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
}

.scroll-anchor {
  height: 20rpx;
}

/* ==================== 输入区域 ==================== */
.input-area {
  background: #fffbf5;
  border-top: 2rpx solid #e8ded2;
  padding: 12rpx 24rpx;
  position: relative;
  z-index: 2;
}

/* 工具栏 */
.toolbar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.toolbar-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(212,184,134,0.1);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #c19a6b;
  font-weight: 400;
}

.toolbar-btn:active {
  background: rgba(212,184,134,0.2);
}

.toolbar-icon {
  font-size: 20rpx;
}

/* 待上传图片 */
.pending-images {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.pending-img-item {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e8ded2;
}

.pending-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.remove-img {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 24rpx;
  height: 24rpx;
  background: #f08080;
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

/* 输入框 */
.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.add-image-btn {
  width: 56rpx;
  height: 56rpx;
  background: rgba(212,184,134,0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.add-image-btn:active {
  background: rgba(212,184,134,0.2);
}

.message-input {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #e8ded2;
  font-size: 26rpx;
  color: #5c4b37;
  box-shadow: inset 0 2rpx 4rpx rgba(139,115,85,0.05);
}

.message-input::placeholder {
  color: #998675;
  font-weight: 300;
}

.send-btn {
  width: 56rpx;
  height: 56rpx;
  background: #e8ded2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.2);
}

.send-btn:active {
  transform: scale(0.96);
}

.send-icon {
  font-size: 20rpx;
  color: #998675;
}

.send-btn.active .send-icon {
  color: #fff;
}

/* ==================== 历史记录弹窗 ==================== */
.history-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.history-modal.show .history-panel {
  transform: translateX(0);
}

.history-modal.hide .history-panel {
  transform: translateX(100%);
}

.history-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4rpx);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.history-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: 85%;
  max-width: 600rpx;
  height: 100%;
  background: #fffbf5;
  box-shadow: -8rpx 0 24rpx rgba(139,115,85,0.15);
  display: flex;
  flex-direction: column;
  transition: transform 0.3s ease;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 24rpx 20rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  border-bottom: 2rpx solid rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.history-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}

.history-count {
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 300;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.clear-btn {
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 400;
}

.clear-btn:active {
  background: rgba(255,255,255,0.3);
}

.history-close {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.history-list {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #fffbf5;
  height: 100%;
  min-height: 0;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(139,115,85,0.06);
  transition: all 0.2s;
  flex-shrink: 0;
}

.history-item:active {
  transform: scale(0.98);
}

.history-item.active {
  border-color: #94c973;
  background: rgba(148,201,115,0.08);
}

.history-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  margin-right: 12rpx;
}

.history-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.history-item-content {
  flex: 1;
  min-width: 0;
}

.history-preview {
  display: block;
  font-size: 26rpx;
  color: #5c4b37;
  margin-bottom: 6rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-time {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
}

.history-delete {
  font-size: 28rpx;
  opacity: 0.5;
  padding: 12rpx;
  flex-shrink: 0;
  transition: opacity 0.2s;
}

.history-delete:active {
  opacity: 1;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  flex-shrink: 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #5c4b37;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #998675;
  font-weight: 300;
}

.history-footer {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #e8ded2;
  background: #fffbf5;
  flex-shrink: 0;
}

.history-new-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  padding: 20rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(148,201,115,0.3);
}

.btn-icon {
  font-size: 32rpx;
  font-weight: 300;
}

/* 公共动画 */
@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}