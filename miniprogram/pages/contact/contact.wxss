/* 联系我们页 - 日系治愈原木风 */
.container {
  background-color: #f9f5f0;
  background-image:
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 60 Q20 55 40 60 T80 60 T100 60" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 80 Q20 75 40 80 T80 80 T100 80" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>');
  background-size: 100rpx 100rpx;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ==================== 页面标题 - 原木渐变标题栏 ==================== */
.page-header {
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  padding: 48rpx 24rpx 36rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(139,115,85,0.15);
}

.header-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #5c4b37;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(92,75,55,0.7);
  letter-spacing: 1rpx;
}

/* ==================== 通用区块 - 卡片样式 ==================== */
.section {
  background: #fffbf5;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 2rpx solid #e8ded2;
  box-shadow:
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  position: relative;
}

/* 和纸胶带装饰 */
.section::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  width: 80rpx;
  height: 20rpx;
  background: rgba(184,216,190,0.4);
  border-radius: 2rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5c4b37;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #e8ded2;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-title::before {
  content: '📞';
  font-size: 24rpx;
}

/* ==================== 联系方式列表 - 原木卡片条目 ==================== */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f0ea;
  background: #fffbf5;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background: rgba(184,216,190,0.1);
}

.contact-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  box-shadow: 0 2rpx 6rpx rgba(139,115,85,0.1);
}

.contact-icon.phone { background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%); }
.contact-icon.wechat { background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%); }
.contact-icon.qq { background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%); }
.contact-icon.email { background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%); }

.contact-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.contact-label {
  font-size: 22rpx;
  color: #998675;
}

.contact-value {
  font-size: 28rpx;
  color: #5c4b37;
  font-weight: 500;
}

.contact-action {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 22rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 0 rgba(148,201,115,0.4);
}

/* ==================== 工作时间 ==================== */
.work-time {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.time-icon {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.3);
}

.time-info {
  flex: 1;
}

.time-label {
  font-size: 24rpx;
  color: #998675;
  margin-bottom: 4rpx;
}

.time-value {
  font-size: 26rpx;
  color: #5c4b37;
  font-weight: 500;
}

.time-notice {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(184,216,190,0.15);
  border: 2rpx solid rgba(148,201,115,0.3);
  border-radius: 12rpx;
  margin-top: 8rpx;
}

.notice-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #5c4b37;
  line-height: 1.5;
}

/* ==================== 常见问题 - 日系问答风格 ==================== */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.faq-item {
  border-bottom: 1rpx solid #f5f0ea;
  overflow: hidden;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
  transition: all 0.2s;
}

.question-icon {
  font-size: 20rpx;
  flex-shrink: 0;
  color: #94c973;
  font-weight: bold;
}

.question-text {
  flex: 1;
  font-size: 26rpx;
  color: #5c4b37;
  font-weight: 500;
}

.faq-answer {
  padding: 0 0 20rpx 32rpx;
}

.answer-text {
  font-size: 24rpx;
  color: #7a6f63;
  line-height: 1.6;
}

/* ==================== 其他服务 - 网格卡片 ==================== */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-card {
  background: linear-gradient(135deg, #fffbf5 0%, #f9f5f0 100%);
  border: 2rpx solid #e8ded2;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  transition: all 0.2s;
}

.action-card:active {
  transform: scale(0.98);
  background: rgba(184,216,190,0.1);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #5c4b37;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 20rpx;
  color: #998675;
}

/* ==================== 在线留言 - 日系表单风格 ==================== */
.message-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-group {
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 18rpx 20rpx;
  background: #fffbf5;
  border: 2rpx solid #e8ded2;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #5c4b37;
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-input:focus {
  border-color: #94c973;
  box-shadow: 0 0 0 3rpx rgba(148,201,115,0.2);
}

.form-textarea-group {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 140rpx;
  background: #fffbf5;
  border: 2rpx solid #e8ded2;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: #5c4b37;
  line-height: 1.5;
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-textarea:focus {
  border-color: #94c973;
  box-shadow: 0 0 0 3rpx rgba(148,201,115,0.2);
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #998675;
  margin-top: 8rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #e8ded2 0%, #d4c6b0 100%);
  color: #998675;
  border-radius: 50rpx;
  padding: 22rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.active {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  box-shadow: 0 4rpx 0 rgba(148,201,115,0.4);
}

.submit-btn.active:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 0 rgba(148,201,115,0.4);
}
