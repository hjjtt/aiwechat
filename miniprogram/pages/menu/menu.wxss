/* 点餐页 - 日系治愈原木风 */
page {
  background: #f9f5f0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>'),
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" opacity="0.03"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="200" height="200" filter="url(%23noise)"/></svg>');
  background-size: 100rpx 100rpx, 200rpx 200rpx;
}

.container {
  min-height: 100vh;
  padding-top: 20rpx;
}

/* ==================== 搜索栏 ==================== */
.search-section {
  padding: 0 24rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f9f5f0;
  background-image: inherit;
  background-size: inherit;
  padding-bottom: 12rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fffbf5;
  padding: 20rpx 24rpx;
  border-radius: 50rpx;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  border: 2rpx solid #e8ded2;
  overflow: hidden;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.7;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #5c4b37;
  background: transparent;
  border: none;
  outline: none;
  font-weight: 300;
}

.search-input::placeholder {
  color: #998675;
}

.search-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.2);
  border: 1rpx solid #fff;
  flex-shrink: 0;
}

.search-btn:active {
  transform: scale(0.96);
}

/* ==================== 分类标签 ==================== */
.category-scroll {
  padding: 0 24rpx 16rpx;
  background: #f9f5f0;
  background-image: inherit;
  background-size: inherit;
  position: sticky;
  top: 100rpx;
  z-index: 9;
}

.category-list {
  display: flex;
  white-space: nowrap;
  gap: 12rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fffbf5;
  border-radius: 24rpx;
  border: 2rpx solid #e8ded2;
  transition: all 0.2s;
  transform: rotate(calc(var(--rotate, 0) * 0.5deg));
  position: relative;
}

.category-item:nth-child(odd) { --rotate: -1; }
.category-item:nth-child(even) { --rotate: 1; }

.category-item.active {
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  border-color: #c19a6b;
  box-shadow: 0 2rpx 4rpx rgba(193,154,107,0.2);
}

.category-item:active {
  transform: scale(0.96) rotate(calc(var(--rotate, 0) * 0.5deg));
}

.cat-icon {
  margin-right: 8rpx;
  font-size: 22rpx;
}

.cat-text {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 400;
}

.category-item.active .cat-text {
  color: #fff;
  font-weight: 500;
}

/* ==================== 菜品列表 ==================== */
.menu-scroll {
  height: calc(100vh - 260rpx);
  padding: 0 24rpx 120rpx;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  background: #fffbf5;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #e8ded2;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  position: relative;
  transform: rotate(var(--rotate, 0deg));
  transition: all 0.2s;
}

.menu-card:nth-child(odd) { --rotate: -0.5deg; }
.menu-card:nth-child(even) { --rotate: 0.3deg; }

.menu-card:active {
  transform: translateY(2rpx) rotate(var(--rotate, 0deg)) scale(0.98);
  box-shadow: 
    0 1rpx 0 #e8ded2,
    0 3rpx 6rpx rgba(139,115,85,0.08);
}

/* 和纸胶带装饰 */
.menu-card::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50rpx;
  width: 70rpx;
  height: 16rpx;
  background: rgba(var(--tape-color, 212,184,134), 0.4);
  border-radius: 2rpx;
  transform: rotate(-3deg);
}

.menu-card:nth-child(3n) { --tape-color: 184,216,190; }
.menu-card:nth-child(3n+1) { --tape-color: 240,208,160; }
.menu-card:nth-child(3n+2) { --tape-color: 212,184,134; }

/* 热销标签 */
.card-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #f0d0a0 0%, #e8b86d 100%);
  color: #fff;
  font-size: 20rpx;
  border-radius: 12rpx 2rpx 12rpx 12rpx;
  transform: rotate(5deg);
  z-index: 2;
  border: 1rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(232,184,109,0.2);
  font-weight: 500;
}

.card-emoji {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid #fff;
  box-shadow: 0 3rpx 8rpx rgba(193,154,107,0.2);
  animation: floatSoft 4s ease-in-out infinite;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #5c4b37;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #998675;
  margin-bottom: 12rpx;
  font-weight: 300;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 20rpx;
  color: #c19a6b;
  font-weight: 500;
}

.price-num {
  font-size: 28rpx;
  color: #c19a6b;
  font-weight: 600;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #fff;
  transition: all 0.2s;
}

.qty-btn:active {
  transform: scale(0.9);
}

.qty-btn.decrease {
  background: #f1ebe4;
  color: #998675;
}

.qty-btn.decrease.active {
  background: linear-gradient(135deg, #f5a9a9 0%, #f08080 100%);
  color: #fff;
  box-shadow: 0 2rpx 4rpx rgba(240,128,128,0.2);
}

.qty-btn.increase {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.2);
}

.qty-value {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 500;
  min-width: 28rpx;
  text-align: center;
  transition: all 0.2s;
}

.qty-value.hide {
  opacity: 0;
  min-width: 0;
  transform: scale(0);
}

.qty-value.show {
  opacity: 1;
  transform: scale(1);
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  font-size: 28rpx;
  opacity: 0.5;
  transition: all 0.2s;
}

.favorite-btn.active {
  opacity: 1;
  transform: scale(1.2);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
  animation: floatSoft 4s ease-in-out infinite;
}

.empty-text {
  font-size: 28rpx;
  color: #5c4b37;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
}

/* ==================== 购物车底部栏 ==================== */
.cart-bar {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  background: #fffbf5;
  border-radius: 24rpx;
  box-shadow: 
    0 4rpx 0 #e8ded2,
    0 8rpx 24rpx rgba(139,115,85,0.15);
  border: 2rpx solid #e8ded2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 20;
}

.cart-main {
  display: flex;
  align-items: center;
  padding: 24rpx;
  flex: 1;
}

.cart-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  border: 2rpx solid #fff;
  box-shadow: 0 3rpx 8rpx rgba(193,154,107,0.2);
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: #f08080;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx;
  border: 1rpx solid #fff;
}

.cart-total {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 24rpx;
  color: #998675;
  margin-right: 4rpx;
  font-weight: 300;
}

.total-price {
  font-size: 32rpx;
  color: #c19a6b;
  font-weight: 600;
}

.checkout-btn {
  padding: 28rpx 48rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 0 20rpx 20rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 3rpx 8rpx rgba(148,201,115,0.2);
  border: 1rpx solid #fff;
}

.checkout-btn:active {
  transform: scale(0.98);
}

.checkout-btn.large {
  border-radius: 20rpx;
  padding: 20rpx 40rpx;
  font-size: 24rpx;
}

/* ==================== 购物车弹窗 ==================== */
.cart-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
  backdrop-filter: blur(4rpx);
}

.cart-popup {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: -100%;
  max-height: 70vh;
  background: #fffbf5;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 16rpx rgba(139,115,85,0.1);
  border: 2rpx solid #e8ded2;
  z-index: 100;
  transition: all 0.3s ease;
}

.cart-popup.show {
  bottom: 0;
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx dashed #e8ded2;
  position: relative;
}

.cart-header::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 8rpx;
  background: #e8ded2;
  border-radius: 4rpx;
}

.cart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5c4b37;
}

.clear-btn {
  font-size: 24rpx;
  color: #f08080;
  font-weight: 400;
  border-bottom: 1rpx dotted #f08080;
}

.cart-items {
  padding: 16rpx 32rpx;
  max-height: calc(70vh - 200rpx);
}

.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(232,222,210,0.5);
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item-info {
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  font-size: 26rpx;
  color: #5c4b37;
  font-weight: 500;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cart-item-price {
  font-size: 22rpx;
  color: #c19a6b;
  font-weight: 500;
}

.cart-item-qty {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-number {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 500;
  min-width: 32rpx;
  text-align: center;
}

.cart-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx dashed #e8ded2;
}

.cart-total-wrap {
  display: flex;
  align-items: baseline;
}

.cart-total-label {
  font-size: 24rpx;
  color: #998675;
  margin-right: 4rpx;
  font-weight: 300;
}

.cart-total-price {
  font-size: 30rpx;
  color: #c19a6b;
  font-weight: 600;
}

/* 公共动画 */
@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}