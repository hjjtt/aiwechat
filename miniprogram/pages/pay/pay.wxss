/* 支付页 - 日系治愈原木风 */
.container {
  background-color: #f9f5f0;
  background-image:
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 60 Q20 55 40 60 T80 60 T100 60" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 80 Q20 75 40 80 T80 80 T100 80" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>');
  background-size: 100rpx 100rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 80rpx;
  padding-bottom: 140rpx;
}

/* ==================== 头部 - 原木标题栏 ==================== */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-bottom: 2rpx solid #c19a6b;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(139,115,85,0.15);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid rgba(255,255,255,0.6);
  transition: all 0.2s;
}

.back-btn:active {
  background: rgba(255,255,255,0.6);
  transform: scale(0.95);
}

.back-icon {
  font-size: 40rpx;
  color: #5c4b37;
  font-weight: 500;
  line-height: 1;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #5c4b37;
  letter-spacing: 4rpx;
  margin-right: 60rpx;
}

/* ==================== 通用区块 ==================== */
.section {
  background: #fffbf5;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 2rpx solid #e8ded2;
  box-shadow:
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  position: relative;
}

/* 和纸胶带装饰 */
.section::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  width: 80rpx;
  height: 20rpx;
  background: rgba(184,216,190,0.4);
  border-radius: 2rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5c4b37;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #e8ded2;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '📋';
  font-size: 24rpx;
  margin-right: 10rpx;
}

/* ==================== 订单信息 - 账单明细 ==================== */
.order-detail {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.label {
  font-size: 26rpx;
  color: #998675;
}

.value {
  font-size: 26rpx;
  color: #5c4b37;
  font-weight: 500;
}

/* ==================== 支付金额 - 清新突出 ==================== */
.amount-section {
  text-align: center;
  padding: 48rpx 24rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  border-color: #94c973;
  box-shadow:
    0 4rpx 0 rgba(148,201,115,0.3),
    0 8rpx 16rpx rgba(148,201,115,0.15);
}

.amount-section::before {
  background: rgba(232,213,183,0.5);
}

.amount-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.amount-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
}

.currency {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.amount {
  font-size: 80rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
  letter-spacing: 2rpx;
}

/* ==================== 支付方式 - 原木卡片选项 ==================== */
.payment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #e8ded2;
  border-radius: 16rpx;
  transition: all 0.2s;
  background: #fffbf5;
}

.payment-item:active {
  transform: scale(0.98);
}

.payment-item.active {
  border-color: #94c973;
  background: linear-gradient(135deg, rgba(184,216,190,0.1) 0%, rgba(148,201,115,0.05) 100%);
  box-shadow: 0 2rpx 0 #94c973;
}

.pay-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(139,115,85,0.1);
}

.pay-icon text {
  font-size: 32rpx;
}

.pay-icon.wechat {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
}

.pay-icon.balance {
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
}

.pay-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pay-name {
  font-size: 28rpx;
  color: #5c4b37;
  font-weight: 600;
}

.pay-desc {
  font-size: 22rpx;
  color: #998675;
}

.pay-check {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.3);
}

/* ==================== 底部支付栏 - 清新底栏 ==================== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fffbf5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #e8ded2;
  box-shadow: 0 -4rpx 12rpx rgba(139,115,85,0.08);
  z-index: 10;
  margin-top: auto;
}

.footer-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.footer-label {
  font-size: 24rpx;
  color: #998675;
}

.footer-price {
  font-size: 40rpx;
  color: #94c973;
  font-weight: 700;
}

.pay-btn {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #fff;
  box-shadow:
    0 4rpx 0 rgba(148,201,115,0.4),
    0 4rpx 12rpx rgba(148,201,115,0.2);
  transition: all 0.2s;
  letter-spacing: 2rpx;
}

.pay-btn:active:not(.disabled) {
  transform: translateY(2rpx);
  box-shadow:
    0 2rpx 0 rgba(148,201,115,0.4),
    0 2rpx 6rpx rgba(148,201,115,0.2);
}

.pay-btn.disabled {
  background: linear-gradient(135deg, #e8ded2 0%, #d4c6b0 100%);
  color: #998675;
  border-color: #e8ded2;
  box-shadow: none;
}
