<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="header-title">订单支付</text>
  </view>

  <!-- 订单信息 -->
  <view class="section order-info-section">
    <view class="section-title">订单信息</view>
    <view class="order-detail">
      <view class="detail-row">
        <text class="label">订单号</text>
        <text class="value">{{orderInfo.orderNumber}}</text>
      </view>
      <view class="detail-row">
        <text class="label">商品数量</text>
        <text class="value">{{orderInfo.itemCount}}件</text>
      </view>
      <view class="detail-row">
        <text class="label">下单时间</text>
        <text class="value">{{orderInfo.createdAt}}</text>
      </view>
    </view>
  </view>

  <!-- 支付金额 -->
  <view class="section amount-section">
    <view class="amount-label">支付金额</view>
    <view class="amount-value">
      <text class="currency">¥</text>
      <text class="amount">{{orderInfo.totalAmount}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="section payment-section">
    <view class="section-title">选择支付方式</view>
    <view class="payment-list">
      <view class="payment-item {{selectedPayMethod === 'wechat' ? 'active' : ''}}" bindtap="selectPayMethod" data-method="wechat">
        <view class="pay-icon wechat">
          <text>💚</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">微信支付</text>
          <text class="pay-desc">推荐使用微信支付</text>
        </view>
        <view class="pay-check" wx:if="{{selectedPayMethod === 'wechat'}}">✓</view>
      </view>
      <view class="payment-item {{selectedPayMethod === 'balance' ? 'active' : ''}}" bindtap="selectPayMethod" data-method="balance">
        <view class="pay-icon balance">
          <text>💰</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">余额支付</text>
          <text class="pay-desc">当前余额：¥{{balance}}</text>
        </view>
        <view class="pay-check" wx:if="{{selectedPayMethod === 'balance'}}">✓</view>
      </view>
    </view>
  </view>

  <!-- 底部支付栏 -->
  <view class="footer-bar">
    <view class="footer-left">
      <text class="footer-label">实付</text>
      <text class="footer-price">¥{{orderInfo.totalAmount}}</text>
    </view>
    <view 
      class="pay-btn {{paying ? 'disabled' : ''}}" 
      bindtap="handlePay"
    >
      <text>{{paying ? '支付中...' : '立即支付'}}</text>
    </view>
  </view>
</view>
