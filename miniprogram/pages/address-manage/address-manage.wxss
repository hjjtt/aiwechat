/* 地址管理页 - 日系治愈原木风 */
page {
  background: #f9f5f0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>'),
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" opacity="0.03"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="200" height="200" filter="url(%23noise)"/></svg>');
  background-size: 100rpx 100rpx, 200rpx 200rpx;
}

.container {
  min-height: 100vh;
  position: relative;
}

/* ==================== 顶部背景 ==================== */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 50%, #b8d8be 100%);
  overflow: hidden;
  z-index: 0;
}

.header-bg::before,
.header-bg::after {
  content: '';
  position: absolute;
  opacity: 0.6;
}

.header-bg::before {
  content: '📍';
  top: 80rpx;
  left: 60rpx;
  font-size: 32rpx;
  animation: floatSoft 5s ease-in-out infinite;
}

.header-bg::after {
  content: '🏠';
  top: 100rpx;
  right: 80rpx;
  font-size: 28rpx;
  animation: floatSoft 6s ease-in-out infinite reverse;
}

.header-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text x="15" y="25" font-size="10" fill="rgba(255,255,255,0.2)">🌱</text><text x="65" y="50" font-size="8" fill="rgba(255,255,255,0.15)">🍃</text></svg>');
  background-size: 120rpx 120rpx;
}

/* ==================== 页面标题 ==================== */
.page-header {
  position: relative;
  z-index: 2;
  padding: 60rpx 24rpx 40rpx;
  text-align: center;
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 1rpx 1rpx 4rpx rgba(139,115,85,0.2);
}

/* ==================== 滚动区域 ==================== */
.address-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - 280rpx);
  padding: 0 24rpx 40rpx;
}

/* 通用卡片样式 */
.address-card,
.detail-card,
.contact-card,
.label-card,
.default-card {
  background: #fffbf5;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e8ded2;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  position: relative;
  transform: rotate(var(--rotate, 0deg));
}

.address-card { --rotate: -0.5deg; }
.detail-card { --rotate: 0.3deg; }
.contact-card { --rotate: -0.2deg; }
.label-card { --rotate: 0.4deg; }
.default-card { --rotate: -0.3deg; }

/* 和纸胶带装饰 */
.address-card::before,
.detail-card::before,
.contact-card::before,
.label-card::before,
.default-card::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50rpx;
  width: 70rpx;
  height: 16rpx;
  background: rgba(var(--tape-color, 212,184,134), 0.4);
  border-radius: 2rpx;
  transform: rotate(-3deg);
}

.address-card::before { --tape-color: 212,184,134; }
.contact-card::before { --tape-color: 184,216,190; }
.label-card::before { --tape-color: 240,169,169; }
.default-card::before { --tape-color: 184,216,232; }

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  width: 44rpx;
  height: 44rpx;
  background: rgba(212,184,134,0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #5c4b37;
  flex: 1;
}

.card-action {
  font-size: 22rpx;
  color: #c19a6b;
  font-weight: 400;
  flex-shrink: 0;
  border-bottom: 1rpx dotted #c19a6b;
}

/* 地址显示 */
.address-display {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #e8ded2;
  box-shadow: inset 0 2rpx 4rpx rgba(139,115,85,0.05);
}

.address-display.empty {
  text-align: center;
}

.address-text {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 400;
  line-height: 1.5;
}

.address-placeholder {
  font-size: 24rpx;
  color: #998675;
  font-weight: 300;
}

/* 表单样式 */
.form-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(232,222,210,0.5);
}

.form-item.no-border {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 22rpx;
  color: #998675;
  margin-bottom: 10rpx;
  font-weight: 300;
  padding-left: 4rpx;
}

.form-input {
  width: 100%;
  font-size: 26rpx;
  color: #5c4b37;
  background: transparent;
  border: none;
  outline: none;
  font-weight: 400;
}

.form-placeholder {
  color: #998675;
  font-weight: 300;
}

/* 地址标签 */
.label-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.label-item {
  padding: 10rpx 20rpx;
  background: #f1ebe4;
  border-radius: 16rpx;
  border: 2rpx solid #e8ded2;
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 400;
  transition: all 0.2s;
  transform: rotate(var(--rotate, 0deg));
}

.label-item:nth-child(odd) { --rotate: -1deg; }
.label-item:nth-child(even) { --rotate: 0.8deg; }

.label-item.active {
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  border-color: #c19a6b;
  color: #fff;
  transform: translateY(-2rpx) rotate(var(--rotate, 0deg));
}

.label-item:active {
  transform: scale(0.96) rotate(var(--rotate, 0deg));
}

/* 默认地址开关 */
.default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.default-left {
  display: flex;
  align-items: center;
}

.default-icon {
  width: 44rpx;
  height: 44rpx;
  background: rgba(240,208,160,0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.default-text {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 400;
}

/* 开关样式覆盖 */
switch {
  transform: scale(0.8);
}

switch[checked] {
  --switch-checked-color: #94c973;
}

/* 已保存地址 */
.saved-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #5c4b37;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.saved-item {
  display: flex;
  align-items: center;
  background: #fffbf5;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid #e8ded2;
  box-shadow: 
    0 2rpx 0 #e8ded2,
    0 4rpx 8rpx rgba(139,115,85,0.08);
  transition: all 0.2s;
}

.saved-item:active {
  transform: scale(0.98);
}

.saved-content {
  flex: 1;
  min-width: 0;
}

.saved-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.saved-tag {
  padding: 2rpx 8rpx;
  background: rgba(148,201,115,0.1);
  color: #94c973;
  font-size: 18rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.saved-label {
  padding: 2rpx 8rpx;
  background: rgba(212,184,134,0.1);
  color: #c19a6b;
  font-size: 18rpx;
  border-radius: 6rpx;
  font-weight: 400;
}

.saved-info {
  font-size: 22rpx;
  color: #5c4b37;
  margin-bottom: 4rpx;
  font-weight: 400;
}

.saved-address {
  font-size: 20rpx;
  color: #998675;
  font-weight: 300;
  line-height: 1.4;
}

.saved-arrow {
  font-size: 24rpx;
  color: #998675;
  font-weight: 300;
  flex-shrink: 0;
}

.bottom-space {
  height: 40rpx;
}

/* ==================== 底部保存按钮 ==================== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fffbf5;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8ded2;
  z-index: 10;
}

.save-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
  box-shadow: 
    0 4rpx 0 #75a757,
    0 6rpx 12rpx rgba(148,201,115,0.3);
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.save-btn:active {
  transform: translateY(2rpx);
  box-shadow: 
    0 2rpx 0 #75a757,
    0 4rpx 8rpx rgba(148,201,115,0.2);
}

/* 公共动画 */
@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}