/* 首页 - 日系治愈原木风 */
.container {
  padding: 0;
  background-color: #f9f5f0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 60 Q20 55 40 60 T80 60 T100 60" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 80 Q20 75 40 80 T80 80 T100 80" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>'),
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" opacity="0.03"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="200" height="200" filter="url(%23noise)"/></svg>');
  background-size: 100rpx 100rpx, 200rpx 200rpx;
  background-position: 0 0, 0 0;
  min-height: 100vh;
  position: relative;
}

/* ==================== 顶部渐变背景 - 浅木色渐变 ==================== */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 50%, #b8d8be 100%);
  z-index: 0;
  overflow: hidden;
}

/* 手绘小装饰 */
.header-bg::before,
.header-bg::after {
  content: '';
  position: absolute;
  opacity: 0.6;
}

.header-bg::before {
  content: '🍞';
  top: 60rpx;
  left: 80rpx;
  font-size: 32rpx;
  animation: floatSoft 5s ease-in-out infinite;
}

.header-bg::after {
  content: '☕';
  top: 120rpx;
  right: 100rpx;
  font-size: 36rpx;
  animation: floatSoft 6s ease-in-out infinite reverse;
}

.header-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text x="15" y="25" font-size="10" fill="rgba(255,255,255,0.2)">🌿</text><text x="65" y="50" font-size="8" fill="rgba(255,255,255,0.15)">🍃</text><text x="30" y="75" font-size="9" fill="rgba(255,255,255,0.18)">🌱</text></svg>');
  background-size: 120rpx 120rpx;
}

/* ==================== 主横幅区域 ==================== */
.hero-section {
  position: relative;
  z-index: 5;
  padding: 60rpx 40rpx 70rpx;
  text-align: center;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255,251,245,0.4);
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  margin-bottom: 28rpx;
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255,255,255,0.6);
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  background: #94c973;
  border-radius: 50%;
  margin-right: 10rpx;
  animation: pulseSoft 2s ease-in-out infinite;
}

@keyframes pulseSoft {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(0.9); }
}

.hero-badge .badge-text {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 500;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 1rpx 1rpx 4rpx rgba(139,115,85,0.2);
  letter-spacing: 6rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(92,75,55,0.85);
  margin-bottom: 32rpx;
  font-weight: 400;
}

/* 搜索框 - 陶瓷碗风格 */
.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255,251,245,0.95);
  margin: 0 auto 28rpx;
  padding: 20rpx 32rpx;
  border-radius: 50rpx;
  width: 80%;
  box-shadow: 
    0 4rpx 12rpx rgba(139,115,85,0.1),
    inset 0 1rpx 2rpx rgba(255,255,255,0.8);
  border: 1rpx solid rgba(232,222,210,0.8);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.7;
}

.search-placeholder {
  font-size: 26rpx;
  color: #998675;
  font-weight: 300;
}

/* 定位栏 - 米黄标签风格 */
.location-bar {
  display: flex;
  align-items: center;
  background: rgba(255,251,245,0.9);
  margin: 0 auto 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  width: 80%;
  box-shadow: 0 2rpx 8rpx rgba(139,115,85,0.1);
  border: 1rpx solid rgba(232,222,210,0.8);
}

.location-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  opacity: 0.7;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-text {
  font-size: 24rpx;
  color: #5c4b37;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 400;
}

.location-tip {
  font-size: 20rpx;
  color: #c19a6b;
  margin-top: 4rpx;
}

.location-refresh {
  padding: 8rpx;
  font-size: 24rpx;
  opacity: 0.7;
  transition: transform 0.3s ease;
}

.location-refresh.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.location-bar:active {
  background: rgba(255,251,245,1);
  transform: scale(0.98);
}

.hero-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.tag-pill {
  display: flex;
  align-items: center;
  background: rgba(255,251,245,0.3);
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #5c4b37;
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  transform: rotate(calc(var(--rotate, 0) * 1deg));
  animation: floatSoft 4s ease-in-out infinite;
}

.tag-pill:nth-child(1) { --rotate: -1.5; animation-delay: 0s; }
.tag-pill:nth-child(2) { --rotate: 1; animation-delay: 0.6s; }
.tag-pill:nth-child(3) { --rotate: -0.5; animation-delay: 1.2s; }

.tag-emoji {
  margin-right: 6rpx;
  font-size: 20rpx;
}

/* ==================== 快捷功能区 - 原木卡片风格 ==================== */
.action-section {
  position: relative;
  z-index: 10;
  padding: 0 24rpx;
  margin-top: -20rpx;
}

.action-card {
  background: #fffbf5;
  border-radius: 24rpx;
  box-shadow: 
    0 4rpx 0 #e8ded2,
    0 8rpx 20rpx rgba(139,115,85,0.1);
  overflow: hidden;
  border: 2rpx solid #e8ded2;
  position: relative;
}

/* 和纸胶带装饰 */
.action-card::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  width: 100rpx;
  height: 20rpx;
  background: rgba(184,216,190,0.4);
  border-radius: 2rpx;
}

.action-grid {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  position: relative;
  transition: all 0.2s;
}

.action-item:active {
  transform: scale(0.96);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  flex-shrink: 0;
  border: 2rpx solid #fff;
  box-shadow: 0 3rpx 8rpx rgba(139,115,85,0.15);
}

.action-icon .action-icon-emoji {
  font-size: 36rpx;
}

.bg-gradient-purple {
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
}

.bg-gradient-orange {
  background: linear-gradient(135deg, #f0d0a0 0%, #e8b86d 100%);
}

.bg-gradient-blue {
  background: linear-gradient(135deg, #b8d8e8 0%, #8ab6d6 100%);
}

.bg-gradient-green {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
}

.action-info {
  text-align: center;
}

.action-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #5c4b37;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 20rpx;
  color: #998675;
  font-weight: 300;
}

.action-arrow {
  display: none;
}

.action-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e8ded2;
  flex-shrink: 0;
}

/* ==================== 通用区块 ==================== */
.section {
  padding: 32rpx 24rpx;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-group {
  display: flex;
  align-items: center;
}

.title-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(193,154,107,0.2);
}

.title-icon-wrap.accent {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
}

.title-icon-wrap .title-icon-emoji {
  font-size: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5c4b37;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #c19a6b;
  font-weight: 300;
  border-bottom: 1rpx dotted #c19a6b;
  padding: 8rpx;
  margin: -8rpx;
  transition: all 0.2s;
}

.section-more:active {
  background: rgba(193,154,107,0.1);
  border-radius: 8rpx;
}

.more-arrow {
  margin-left: 4rpx;
  font-weight: 300;
}

/* ==================== 热销推荐 - 手绘卡片风格 ==================== */
.hot-scroll {
  white-space: nowrap;
  width: 100%;
}

.hot-card {
  display: inline-block;
  width: 200rpx;
  background: #fffbf5;
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  margin-right: 16rpx;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  vertical-align: top;
  border: 2rpx solid #e8ded2;
  transition: all 0.2s;
  position: relative;
  transform: rotate(var(--rotate, 0deg));
}

.hot-card:nth-child(odd) { --rotate: -1deg; }
.hot-card:nth-child(even) { --rotate: 0.8deg; }

.hot-card:active {
  transform: translateY(2rpx) rotate(var(--rotate, 0deg)) scale(0.97);
  box-shadow: 
    0 1rpx 0 #e8ded2,
    0 3rpx 6rpx rgba(139,115,85,0.08);
}

/* 手绘小贴纸装饰 */
.card-sticker {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  font-size: 20rpx;
  z-index: 2;
  opacity: 0.8;
}

.hot-card:last-child {
  margin-right: 0;
}

.hot-image {
  font-size: 72rpx;
  text-align: center;
  margin-bottom: 12rpx;
  animation: floatSoft 3s ease-in-out infinite;
}

.hot-info {
  text-align: center;
}

.hot-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #5c4b37;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hot-sales {
  font-size: 18rpx;
  color: #998675;
  margin-bottom: 12rpx;
  font-weight: 300;
}

.hot-footer {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hot-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 20rpx;
  color: #c19a6b;
  font-weight: 500;
}

.price-value {
  font-size: 28rpx;
  color: #c19a6b;
  font-weight: 600;
}

.hot-add {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.3);
  transition: all 0.2s;
}

.hot-add:active {
  transform: scale(0.9);
  box-shadow: 0 1rpx 2rpx rgba(148,201,115,0.3);
}

/* ==================== 营业信息 - 和纸卡片风格 ==================== */
.info-card {
  background: #fffbf5;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  border: 2rpx solid #e8ded2;
  position: relative;
}

/* 侧边和纸胶带 */
.info-card::before {
  content: '';
  position: absolute;
  left: -10rpx;
  top: 50%;
  transform: translateY(-50%) rotate(90deg);
  width: 80rpx;
  height: 20rpx;
  background: rgba(212,184,134,0.4);
  border-radius: 2rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
  border: 1rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(193,154,107,0.2);
}

.info-icon-wrap .info-icon-text {
  font-size: 28rpx;
}

.info-content {
  flex: 1;
  min-width: 0;
}

.info-label {
  font-size: 22rpx;
  color: #998675;
  margin-bottom: 4rpx;
  font-weight: 300;
}

.info-value {
  font-size: 24rpx;
  font-weight: 500;
  color: #5c4b37;
}

/* ==================== 日系店员卡通角色 ==================== */
.cartoon-role {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  z-index: 100;
  animation: floatSoft 4s ease-in-out infinite;
}

.role-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 3rpx solid #fff;
  box-shadow: 
    0 4rpx 0 rgba(193,154,107,0.3),
    0 6rpx 16rpx rgba(193,154,107,0.25);
  position: relative;
  z-index: 2;
}

.role-bubble {
  position: absolute;
  top: -55rpx;
  right: 0;
  background: #fffbf5;
  padding: 10rpx 16rpx;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
  border: 1rpx solid #e8ded2;
  box-shadow: 0 2rpx 6rpx rgba(139,115,85,0.1);
  transform: rotate(-3deg);
  z-index: 1;
}

.bubble-text {
  font-size: 20rpx;
  color: #5c4b37;
  font-weight: 400;
}

.role-deco {
  position: absolute;
  font-size: 18rpx;
  opacity: 0.7;
}

.role-deco-1 {
  top: -8rpx;
  left: -8rpx;
  animation: pulseSoft 2s infinite ease-in-out;
}

.role-deco-2 {
  bottom: -4rpx;
  right: -6rpx;
  animation: pulseSoft 2s infinite ease-in-out 1s;
}

/* ==================== 角落手绘涂鸦 ==================== */
.graffiti {
  position: fixed;
  font-size: 22rpx;
  opacity: 0.5;
  z-index: 0;
  animation: floatSoft 6s infinite ease-in-out;
}

.graffiti-1 {
  top: 380rpx;
  left: 16rpx;
  transform: rotate(10deg);
  animation-delay: 0s;
}

.graffiti-2 {
  top: 580rpx;
  right: 12rpx;
  transform: rotate(-8deg);
  animation-delay: 2s;
}

.graffiti-3 {
  bottom: 180rpx;
  left: 32rpx;
  transform: rotate(15deg);
  animation-delay: 4s;
}

/* ==================== 底部安全提示 ==================== */
.footer-safe {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  border-top: 1rpx dashed #e8ded2;
  margin: 0 24rpx;
}

.safe-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.safe-text {
  font-size: 20rpx;
  color: #998675;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* ==================== 分类快捷入口 - 网格卡片 ==================== */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  background: #fffbf5;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow:
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  border: 2rpx solid #e8ded2;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: linear-gradient(135deg, rgba(184,216,190,0.08) 0%, rgba(148,201,115,0.05) 100%);
  border-radius: 16rpx;
  transition: all 0.2s;
  border: 2rpx solid rgba(184,216,190,0.2);
}

.category-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(184,216,190,0.2) 0%, rgba(148,201,115,0.15) 100%);
  border-color: #94c973;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #5c4b37;
  font-weight: 500;
}
