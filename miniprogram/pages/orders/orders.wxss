/* 订单页 - 日系治愈原木风 */
page {
  background: #f9f5f0;
  background-image: 
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path d="M0 20 Q20 15 40 20 T80 20 T100 20" stroke="#8b7355" fill="none" stroke-width="0.5"/><path d="M0 40 Q20 35 40 40 T80 40 T100 40" stroke="#8b7355" fill="none" stroke-width="0.5"/></svg>'),
    url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" opacity="0.03"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="200" height="200" filter="url(%23noise)"/></svg>');
  background-size: 100rpx 100rpx, 200rpx 200rpx;
}

.container {
  min-height: 100vh;
}

/* ==================== 顶部头部 ==================== */
.header {
  padding: 60rpx 24rpx 32rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 50%, #b8d8be 100%);
  position: relative;
  overflow: hidden;
}

.header::before,
.header::after {
  content: '';
  position: absolute;
  opacity: 0.6;
}

.header::before {
  content: '📦';
  top: 80rpx;
  left: 80rpx;
  font-size: 28rpx;
  animation: floatSoft 5s ease-in-out infinite;
}

.header::after {
  content: '✨';
  top: 100rpx;
  right: 100rpx;
  font-size: 24rpx;
  animation: floatSoft 6s ease-in-out infinite reverse;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-icon {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,251,245,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(255,255,255,0.5);
}

.user-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 1rpx 1rpx 4rpx rgba(139,115,85,0.2);
}

/* ==================== 订单状态筛选栏 ==================== */
.status-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  background: #f9f5f0;
  background-image: inherit;
  background-size: inherit;
  gap: 16rpx;
  overflow-x: scroll;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(139,115,85,0.05);
}

.status-tabs::-webkit-scrollbar {
  display: none;
}

.status-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fffbf5;
  border-radius: 16rpx;
  border: 2rpx solid #e8ded2;
  transition: all 0.2s;
  flex-shrink: 0;
  min-width: 100rpx;
  transform: rotate(var(--rotate, 0deg));
}

.status-tab:nth-child(odd) { --rotate: -0.5deg; }
.status-tab:nth-child(even) { --rotate: 0.5deg; }

.status-tab.active {
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  border-color: #c19a6b;
  box-shadow: 0 2rpx 4rpx rgba(193,154,107,0.2);
  transform: translateY(-2rpx) rotate(var(--rotate, 0deg));
}

.status-tab:active {
  transform: scale(0.96) rotate(var(--rotate, 0deg));
}

.tab-icon {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #5c4b37;
  font-weight: 400;
}

.status-tab.active .tab-text {
  color: #fff;
  font-weight: 500;
}

/* ==================== 加载状态 ==================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-icon {
  margin-bottom: 20rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8ded2;
  border-top-color: #c19a6b;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #998675;
  font-weight: 300;
}

/* ==================== 错误状态 ==================== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.error-text {
  font-size: 24rpx;
  color: #f08080;
  margin-bottom: 24rpx;
  font-weight: 400;
}

.retry-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #d4b886 0%, #c19a6b 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 4rpx rgba(193,154,107,0.2);
  border: 1rpx solid #fff;
}

.retry-btn:active {
  transform: scale(0.96);
}

/* ==================== 订单列表 ==================== */
.order-list {
  height: calc(100vh - 320rpx);
  padding: 0 24rpx 40rpx;
}

.order-card {
  background: #fffbf5;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid #e8ded2;
  box-shadow: 
    0 3rpx 0 #e8ded2,
    0 6rpx 12rpx rgba(139,115,85,0.08);
  position: relative;
  transform: rotate(var(--rotate, 0deg));
  transition: all 0.2s;
}

.order-card:nth-child(odd) { --rotate: -0.3deg; }
.order-card:nth-child(even) { --rotate: 0.2deg; }

.order-card:active {
  transform: translateY(2rpx) rotate(var(--rotate, 0deg)) scale(0.98);
}

/* 和纸胶带装饰 */
.order-card::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 60rpx;
  width: 80rpx;
  height: 16rpx;
  background: rgba(var(--tape-color, 212,184,134), 0.4);
  border-radius: 2rpx;
  transform: rotate(-3deg);
}

.order-card:nth-child(3n) { --tape-color: 184,216,190; }
.order-card:nth-child(3n+1) { --tape-color: 240,208,160; }
.order-card:nth-child(3n+2) { --tape-color: 212,184,134; }

/* 卡片顶部 */
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx dashed #e8ded2;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-number {
  font-size: 24rpx;
  color: #998675;
  margin-bottom: 4rpx;
  font-weight: 300;
}

.order-time {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(193,154,107,0.1);
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-right: 6rpx;
  background: #c19a6b;
}

.status-text {
  font-size: 22rpx;
  color: #c19a6b;
  font-weight: 500;
}

/* 不同状态配色 */
.status-badge.pending { background: rgba(212,184,134,0.1); }
.status-badge.pending .status-dot { background: #d4b886; }
.status-badge.pending .status-text { color: #d4b886; }

.status-badge.confirmed { background: rgba(212,184,134,0.1); }
.status-badge.confirmed .status-dot { background: #d4b886; }
.status-badge.confirmed .status-text { color: #d4b886; }

.status-badge.preparing { background: rgba(240,169,169,0.1); }
.status-badge.preparing .status-dot { background: #f5a9a9; }
.status-badge.preparing .status-text { color: #f5a9a9; }

.status-badge.delivering { background: rgba(138,182,214,0.1); }
.status-badge.delivering .status-dot { background: #8ab6d6; }
.status-badge.delivering .status-text { color: #8ab6d6; }

.status-badge.completed { background: rgba(148,201,115,0.1); }
.status-badge.completed .status-dot { background: #94c973; }
.status-badge.completed .status-text { color: #94c973; }

.status-badge.cancelled { background: rgba(240,128,128,0.1); }
.status-badge.cancelled .status-dot { background: #f08080; }
.status-badge.cancelled .status-text { color: #f08080; }

/* 卡片中部 */
.card-middle {
  padding: 16rpx 24rpx;
}

.items-container {
  margin-bottom: 16rpx;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6rpx 0;
}

.item-info {
  display: flex;
  align-items: center;
}

.item-name {
  font-size: 24rpx;
  color: #5c4b37;
  margin-right: 12rpx;
  font-weight: 400;
}

.item-qty {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
}

.item-price {
  font-size: 24rpx;
  color: #c19a6b;
  font-weight: 500;
}

.divider {
  height: 1rpx;
  background: rgba(232,222,210,0.5);
  margin: 12rpx 0;
}

.total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-label {
  font-size: 24rpx;
  color: #998675;
  font-weight: 300;
}

.total-amount {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 20rpx;
  color: #c19a6b;
  font-weight: 500;
}

.amount {
  font-size: 26rpx;
  color: #c19a6b;
  font-weight: 600;
}

/* 卡片底部 */
.card-bottom {
  padding: 16rpx 24rpx 24rpx;
  border-top: 1rpx dashed #e8ded2;
  display: flex;
  justify-content: flex-end;
}

.btn-group {
  display: flex;
  gap: 12rpx;
}

.btn {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  border: 1rpx solid #fff;
  transition: all 0.2s;
}

.btn:active {
  transform: scale(0.96);
}

.btn-outline {
  background: #f1ebe4;
  color: #5c4b37;
  border: 2rpx solid #e8ded2;
}

.btn-primary {
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.2);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  margin-bottom: 20rpx;
}

.empty-emoji {
  font-size: 100rpx;
  animation: floatSoft 4s ease-in-out infinite;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #5c4b37;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 22rpx;
  color: #998675;
  font-weight: 300;
  margin-bottom: 32rpx;
}

.go-menu-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #b8d8be 0%, #94c973 100%);
  color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(148,201,115,0.2);
  border: 1rpx solid #fff;
}

.go-menu-btn:active {
  transform: scale(0.96);
}

.btn-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

/* 公共动画 */
@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}