<view class="container">
  <!-- 顶部用户信息 -->
  <view class="header">
    <view class="user-info">
      <text class="user-icon">👤</text>
      <text class="user-text">我的订单</text>
    </view>
  </view>

  <!-- 订单状态筛选 -->
  <view class="status-tabs">
    <view class="status-tab {{currentStatus === '' ? 'active' : ''}}" bindtap="switchStatus" data-status="">
      <text class="tab-icon">📦</text>
      <text class="tab-text">全部</text>
    </view>
    <view class="status-tab {{currentStatus === 'pending' ? 'active' : ''}}" bindtap="switchStatus" data-status="pending">
      <text class="tab-icon">⏱️</text>
      <text class="tab-text">待付款</text>
    </view>
    <view class="status-tab {{currentStatus === 'confirmed' ? 'active' : ''}}" bindtap="switchStatus" data-status="confirmed">
      <text class="tab-icon">✅</text>
      <text class="tab-text">待发货</text>
    </view>
    <view class="status-tab {{currentStatus === 'preparing' ? 'active' : ''}}" bindtap="switchStatus" data-status="preparing">
      <text class="tab-icon">👨‍🍳</text>
      <text class="tab-text">准备中</text>
    </view>
    <view class="status-tab {{currentStatus === 'delivering' ? 'active' : ''}}" bindtap="switchStatus" data-status="delivering">
      <text class="tab-icon">🚗</text>
      <text class="tab-text">配送中</text>
    </view>
    <view class="status-tab {{currentStatus === 'completed' ? 'active' : ''}}" bindtap="switchStatus" data-status="completed">
      <text class="tab-icon">🎉</text>
      <text class="tab-text">已完成</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-icon">
      <view class="spinner"></view>
    </view>
    <text class="loading-text">加载订单中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error && !loading && orders.length === 0}}">
    <view class="error-icon">⚠️</view>
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="loadOrders">重新加载</view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-list" scroll-y="true" wx:elif="{{orders.length > 0}}">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" bindtap="viewOrderDetail" data-ordernumber="{{item.orderNumber}}">
        <!-- 卡片顶部：订单号和状态 -->
        <view class="card-top">
          <view class="order-info">
            <text class="order-number">订单号：{{item.orderNumber}}</text>
            <text class="order-time">{{item.createdAt}}</text>
          </view>
          <view class="status-badge {{item.status}}">
            <text class="status-dot"></text>
            <text class="status-text">{{item.status === 'pending' ? 'お支払い' : item.status === 'delivering' ? '配送中' : item.status === 'completed' ? '完了' : getStatusText(item.status)}}</text>
          </view>
        </view>

        <!-- 卡片中部：商品列表 -->
        <view class="card-middle">
          <view class="items-container" wx:if="{{item.items && item.items.length > 0}}">
            <view class="item-row" wx:for="{{item.items}}" wx:for-item="foodItem" wx:key="id">
              <view class="item-info">
                <view class="item-name">{{foodItem.menuName}}</view>
                <view class="item-qty">x{{foodItem.quantity}}</view>
              </view>
              <view class="item-price">¥{{foodItem.subtotal}}</view>
            </view>
          </view>
          <view class="divider"></view>
          <view class="total-row">
            <text class="total-label">合计</text>
            <view class="total-amount">
              <text class="currency">¥</text>
              <text class="amount">{{item.totalAmount}}</text>
            </view>
          </view>
        </view>

        <!-- 卡片底部：操作按钮 -->
        <view class="card-bottom">
          <view class="btn-group" wx:if="{{item.status === 'pending'}}">
            <view class="btn btn-outline" catchtap="cancelOrder" data-ordernumber="{{item.orderNumber}}">取消</view>
            <view class="btn btn-primary" catchtap="goToPay" data-ordernumber="{{item.orderNumber}}">去支付</view>
          </view>
          <view class="btn-group" wx:elif="{{item.status === 'delivering'}}">
            <view class="btn btn-primary" catchtap="confirmReceipt" data-ordernumber="{{item.orderNumber}}">确认收货</view>
          </view>
          <view class="btn-group" wx:elif="{{item.status === 'completed'}}">
            <view class="btn btn-outline" catchtap="viewOrderDetail" data-ordernumber="{{item.orderNumber}}">再来一单</view>
          </view>
          <view class="btn-group" wx:elif="{{item.status === 'cancelled'}}">
            <view class="btn btn-outline" catchtap="viewOrderDetail" data-ordernumber="{{item.orderNumber}}">查看详情</view>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">
      <view class="empty-emoji">📭</view>
    </view>
    <view class="empty-text">暂无订单</view>
    <view class="empty-tip">还没有任何订单记录</view>
    <view class="go-menu-btn" bindtap="goToMenu">
      <text class="btn-icon">🍔</text>
      <text>去点餐</text>
    </view>
  </view>
</view>
