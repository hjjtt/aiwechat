/* 协议页 - 日系治愈原木风 */
page {
  background-color: #f9f5f0;
  min-height: 100vh;
}

.agreement-container {
  min-height: 100vh;
  background-color: #f9f5f0;
}

/* ==================== 顶部导航栏 ==================== */
.navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 88rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #d4b886 50%, #b8d8be 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 115, 85, 0.15);
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #5d4e37;
  line-height: 1;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  color: #5d4e37;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5d4e37;
  max-width: 400rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-placeholder {
  width: 100rpx;
}

/* ==================== 内容滚动区域 ==================== */
.content-scroll {
  height: calc(100vh - 88rpx);
}

.content-wrapper {
  padding: 40rpx 40rpx 60rpx;
}

/* ==================== 协议头部 ==================== */
.agreement-header {
  text-align: center;
  padding-bottom: 40rpx;
  border-bottom: 2rpx solid #e8e0d5;
  margin-bottom: 40rpx;
}

.header-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #5d4e37;
  margin-bottom: 16rpx;
}

.header-update {
  display: block;
  font-size: 24rpx;
  color: #a89f91;
}

/* ==================== 协议内容 ==================== */
.agreement-content {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 115, 85, 0.08);
}

.section {
  margin-bottom: 36rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #5d4e37;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #94c973;
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: #6b5d4f;
  line-height: 1.8;
  margin-bottom: 16rpx;
  text-align: justify;
  word-wrap: break-word;
}

/* ==================== 底部提示 ==================== */
.footer-tip {
  text-align: center;
  padding-top: 40rpx;
  margin-top: 20rpx;
}

.footer-tip text {
  font-size: 24rpx;
  color: #a89f91;
  background: rgba(139, 115, 85, 0.1);
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  display: inline-block;
}
