<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiwechat.admin.repository.ChatRecordRepository">

    <!-- 结果映射 -->
    <resultMap id="ChatRecordResultMap" type="com.aiwechat.admin.model.entity.ChatRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="sessionId" column="session_id"/>
        <result property="question" column="question"/>
        <result property="answer" column="answer"/>
        <result property="sources" column="sources"/>
        <result property="createdAt" column="created_at"/>
        <result property="role" column="role"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, user_id, session_id, question, answer, sources, created_at, role
    </sql>

    <!-- 分页查询聊天记录（支持用户 ID 和关键词筛选） -->
    <select id="findAll" resultMap="ChatRecordResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM chat_records
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (question LIKE CONCAT('%', #{keyword}, '%')
                     OR answer LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计聊天记录数量（支持用户 ID 和关键词筛选） -->
    <select id="countRecords" resultType="int">
        SELECT COUNT(*)
        FROM chat_records
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (question LIKE CONCAT('%', #{keyword}, '%')
                     OR answer LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>

    <!-- 根据 ID 查询聊天记录 -->
    <select id="findById" resultMap="ChatRecordResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM chat_records
        WHERE id = #{id}
    </select>

    <!-- 根据ID删除聊天记录 -->
    <delete id="deleteById">
        DELETE FROM chat_records WHERE id = #{id}
    </delete>

    <!-- 批量删除聊天记录 -->
    <delete id="batchDelete">
        DELETE FROM chat_records
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 清空所有聊天记录 -->
    <delete id="clearAll">
        DELETE FROM chat_records
    </delete>

    <!-- 删除指定天数之前的聊天记录 -->
    <delete id="deleteBeforeDays">
        DELETE FROM chat_records
        WHERE created_at &lt; DATE_SUB(NOW(), INTERVAL #{days} DAY)
    </delete>

    <!-- 查询所有存在聊天记录的用户ID -->
    <select id="findAllUserIds" resultType="java.lang.String">
        SELECT DISTINCT user_id
        FROM chat_records
        WHERE user_id IS NOT NULL AND user_id != ''
        ORDER BY user_id
    </select>

</mapper>
