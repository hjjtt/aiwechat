<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiwechat.menu.repository.MenuItemRepository">

    <!-- 菜品结果映射 -->
    <resultMap id="MenuItemResultMap" type="com.aiwechat.menu.model.entity.MenuItem">
        <id property="id" column="id"/>
        <result property="itemId" column="item_id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="price" column="price"/>
        <result property="category" column="category"/>
        <result property="imageUrl" column="image_url"/>
        <result property="isAvailable" column="is_available"/>
        <result property="salesCount" column="sales_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, item_id, name, description, price, category, image_url, is_available, sales_count,
        created_at, updated_at
    </sql>

    <!-- 根据菜品编号查询 -->
    <select id="findByItemId" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        WHERE item_id = #{itemId}
    </select>

    <!-- 查询所有上架菜品 -->
    <select id="findAllAvailable" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        WHERE is_available = 1
        ORDER BY category, id
    </select>

    <!-- 根据分类查询上架菜品 -->
    <select id="findByCategory" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        WHERE category = #{category} AND is_available = 1
        ORDER BY id
    </select>

    <!-- 搜索菜品（名称或描述模糊匹配） -->
    <select id="search" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        WHERE (name LIKE CONCAT('%', #{keyword}, '%')
               OR description LIKE CONCAT('%', #{keyword}, '%'))
          AND is_available = 1
        ORDER BY id
    </select>

    <!-- 新增菜品 -->
    <insert id="insert" parameterType="com.aiwechat.menu.model.entity.MenuItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO menu_items (item_id, name, description, price, category, image_url,
                                is_available, sales_count, created_at, updated_at)
        VALUES (#{itemId}, #{name}, #{description}, #{price}, #{category}, #{imageUrl},
                #{isAvailable}, #{salesCount}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 更新菜品 -->
    <update id="update" parameterType="com.aiwechat.menu.model.entity.MenuItem">
        UPDATE menu_items
        SET name = #{name},
            description = #{description},
            price = #{price},
            category = #{category},
            image_url = #{imageUrl},
            is_available = #{isAvailable},
            sales_count = #{salesCount},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!-- 更新上架状态（按菜品编号） -->
    <update id="updateAvailability">
        UPDATE menu_items
        SET is_available = #{isAvailable},
            updated_at = NOW()
        WHERE item_id = #{itemId}
    </update>

    <!-- ========== 后台管理相关 ========== -->

    <!-- 根据主键ID查询 -->
    <select id="findById" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        WHERE id = #{id}
    </select>

    <!-- 根据多个主键ID批量查询 -->
    <select id="findByIds" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 分页查询菜品（支持分类和关键词筛选） -->
    <select id="findAllWithFilter" resultMap="MenuItemResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM menu_items
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%')
                     OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY category, id
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计菜品数量（支持分类和关键词筛选） -->
    <select id="count" resultType="int">
        SELECT COUNT(*)
        FROM menu_items
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%')
                     OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>

    <!-- 统计总菜品数 -->
    <select id="countTotal" resultType="int">
        SELECT COUNT(*) FROM menu_items
    </select>

    <!-- 统计上架菜品数 -->
    <select id="countAvailable" resultType="int">
        SELECT COUNT(*) FROM menu_items WHERE is_available = 1
    </select>

    <!-- 统计分类数量 -->
    <select id="countCategories" resultType="int">
        SELECT COUNT(DISTINCT category) FROM menu_items
    </select>

    <!-- 获取所有分类列表 -->
    <select id="findAllCategories" resultType="string">
        SELECT DISTINCT category FROM menu_items WHERE category IS NOT NULL AND category != ''
        ORDER BY category
    </select>

    <!-- 根据主键ID删除菜品 -->
    <delete id="deleteById">
        DELETE FROM menu_items WHERE id = #{id}
    </delete>

    <!-- 根据主键ID更新上架状态 -->
    <update id="updateAvailabilityById">
        UPDATE menu_items
        SET is_available = #{isAvailable},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>
