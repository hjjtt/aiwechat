<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiwechat.knowledge.repository.KnowledgeConceptEdgeRepository">

    <resultMap id="BaseResultMap" type="com.aiwechat.knowledge.model.entity.KnowledgeConceptEdge">
        <id column="id" property="id"/>
        <result column="source_concept_id" property="sourceConceptId"/>
        <result column="target_concept_id" property="targetConceptId"/>
        <result column="edge_type" property="edgeType"/>
        <result column="weight" property="weight"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO knowledge_concept_edges (
            source_concept_id, target_concept_id, edge_type, weight, created_at, updated_at
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.sourceConceptId}, #{item.targetConceptId}, #{item.edgeType},
                #{item.weight}, #{item.createdAt}, #{item.updatedAt}
            )
        </foreach>
    </insert>

    <select id="selectNeighbors" resultMap="BaseResultMap">
        SELECT id, source_concept_id, target_concept_id, edge_type, weight, created_at, updated_at
        FROM knowledge_concept_edges
        WHERE source_concept_id IN
        <foreach collection="conceptIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        OR target_concept_id IN
        <foreach collection="conceptIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY weight DESC, id ASC
        LIMIT #{limit}
    </select>

    <delete id="deleteAll">
        DELETE FROM knowledge_concept_edges
    </delete>
</mapper>
