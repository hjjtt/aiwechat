<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiwechat.knowledge.repository.MenuItemRepository">

    <!-- 查询所有上架菜品 -->
    <select id="findAllAvailable" resultType="com.aiwechat.knowledge.model.entity.MenuItem">
        SELECT id, name, description, price, category, sales_count, is_available
        FROM menu_items
        WHERE is_available = 1
        ORDER BY category, id
    </select>

</mapper>
